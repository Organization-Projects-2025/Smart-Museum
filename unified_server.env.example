# Unified Museum Server Configuration
# Copy this file to .env and uncomment/modify the values you need

# ============================================================================
# Camera Configuration
# ============================================================================

# Camera index to use (0 = default webcam, 1 = second camera, etc.)
# MUSEUM_CAMERA=0

# Mirror camera frames for gaze/emotion service (1 = enabled, 0 = disabled)
# GAZE_EMOTION_MIRROR=0

# ============================================================================
# Service Ports
# ============================================================================

# Face authentication service port
# PYTHON_SERVER_PORT=5000

# Hand tracking service port
# HAND_TRACK_PORT=5004

# ============================================================================
# Service Configuration
# ============================================================================

# YOLO context mode (1 = mock data, 0 = real YOLO with ultralytics)
# YOLO_CONTEXT_MOCK=1

# ============================================================================
# Service Enable/Disable
# ============================================================================

# Disable specific services by setting to 1
# Useful for troubleshooting or when certain features aren't needed

# DISABLE_FACE_AUTH=1
# DISABLE_GESTURE=1
# DISABLE_GAZE_EMOTION=1
# DISABLE_YOLO_CONTEXT=1
# DISABLE_HAND_TRACK=1

# ============================================================================
# Server Mode
# ============================================================================

# Use unified server (recommended) or legacy multi-process mode
# Set to 1 for unified server, 0 or unset for legacy mode
# USE_UNIFIED_SERVER=1